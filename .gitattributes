# ============================================================================
# .gitattributes para r-bmad-data-scientist
# Garante tratamento correto de line endings e tipos de arquivo
# ============================================================================

# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# ============================================================================
# Source Code
# ============================================================================
*.R text
*.r text
*.Rmd text
*.qmd text
*.Rprofile text
*.Renviron text

# ============================================================================
# Documentation
# ============================================================================
*.md text
*.markdown text
*.txt text
*.rst text

# YAML, JSON, XML
*.yaml text
*.yml text
*.json text
*.xml text

# ============================================================================
# Data Files
# ============================================================================
*.csv text eol=lf
*.tsv text eol=lf
*.tab text eol=lf

# Binary data files
*.rds binary
*.RDS binary
*.rda binary
*.RData binary
*.feather binary
*.parquet binary
*.h5 binary

# Excel
*.xlsx binary
*.xls binary

# ============================================================================
# Scripts and Configuration
# ============================================================================
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
*.fish text eol=lf

# Make executable
*.sh text eol=lf
*.bash text eol=lf

# ============================================================================
# Web Files
# ============================================================================
*.html text
*.css text
*.js text
*.htm text

# ============================================================================
# Graphics and Media
# ============================================================================
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text
*.pdf binary
*.eps binary

# ============================================================================
# Archives
# ============================================================================
*.zip binary
*.tar binary
*.gz binary
*.bz2 binary
*.7z binary
*.rar binary

# ============================================================================
# Git Configuration
# ============================================================================
.gitattributes text
.gitignore text
.gitmodules text

# ============================================================================
# R Package Specific
# ============================================================================
DESCRIPTION text
NAMESPACE text
LICENSE text
NEWS text
README text
configure text eol=lf
cleanup text eol=lf

# ============================================================================
# END OF .gitattributes
# ============================================================================
